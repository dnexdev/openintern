# Postgres (Neon or local Docker Compose)
DATABASE_URL=postgresql://openintern:openintern@localhost:5432/openintern

# Auth.js (optional — required for saves/alerts)
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Resend (optional — alert digests)
RESEND_API_KEY=
ALERT_FROM_EMAIL=alerts@openintern.dev

# Rate limiting (requests per minute for /v1)
API_RATE_LIMIT_PER_MINUTE=60
