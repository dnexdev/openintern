# Postgres (Neon or local Docker Compose)
DATABASE_URL=postgresql://openintern:openintern@localhost:5432/openintern

# Rate limiting (requests per minute for /v1)
API_RATE_LIMIT_PER_MINUTE=60

# Optional privacy-friendly analytics (Plausible). Leave unset to disable.
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=openintern.dev

# Proprietary careers (Citadel / Tesla) when CDN returns 403:
# OPENINTERN_BROWSER=1
# OPENINTERN_CITADEL_HTML_PATH=./dumps/citadel-open-opportunities.html
# OPENINTERN_CITADEL_SECURITIES_HTML_PATH=./dumps/citadel-securities-open-opportunities.html
# OPENINTERN_TESLA_STATE_PATH=./dumps/tesla-state.json
# OPENINTERN_ONLY_SLUGS=citadel,citadel-securities,tesla
